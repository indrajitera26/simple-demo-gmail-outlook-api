# Port configuration
PORT=3000

# Gmail OAuth2 Configuration
# To get these credentials:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Gmail API
# 4. Go to "Credentials" -> Create Credentials -> OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Add authorized redirect URI: http://localhost:3000/gmail/auth/callback
# 7. Download the credentials JSON or copy the values below

# From your Google Console credentials:
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:3000/gmail/auth/callback

# Outlook/Microsoft OAuth2 Configuration
# To get these credentials:
# 1. Go to https://portal.azure.com/
# 2. Navigate to Azure Active Directory -> App registrations
# 3. Click "New registration"
# 4. Name your app and select "Accounts in any organizational directory and personal Microsoft accounts"
# 5. Add redirect URI: http://localhost:3000/outlook/auth/callback (Web platform)
# 6. After creation, go to "Certificates & secrets" -> New client secret
# 7. Copy the Application (client) ID and client secret value

# From your Azure App Registration:
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=http://localhost:3000/outlook/auth/callback