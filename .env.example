# Port configuration
PORT=3000

# Gmail OAuth2 Configuration
# To get these credentials:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Gmail API
# 4. Go to "Credentials" -> Create Credentials -> OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Add authorized redirect URI: http://localhost:3000/gmail/auth/callback
# 7. Download the credentials JSON or copy the values below

# From your Google Console credentials (REQUIRED):
GMAIL_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret-here

# Redirect URI (must match exactly what's in Google Console)
GMAIL_REDIRECT_URI=http://localhost:3000/gmail/auth/callback